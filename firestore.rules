rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * WISHSTREAM SECURITY RULES
     * 
     * Architecture:
     * - /userProfiles/{userId}: Profile info.
     * - /userProfiles/{userId}/wishlistItems/{itemId}: The actual wishlist.
     * - /userProfiles/{userId}/guests/{docId}: Guestbook/Friends list.
     * - /sharedWishlistStatuses/{itemId}: Fulfillment tracking.
     */

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Rules ---

    // User Profiles & Subcollections
    match /userProfiles/{userId} {
      // Everyone signed in can view profiles (to see shared wishlists)
      allow read: if isSignedIn();
      // Only the owner can manage their own profile
      allow write: if isOwner(userId);

      // Wishlist Items
      match /wishlistItems/{itemId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }

      // Guestbook/Friends subcollection
      match /guests/{docId} {
        allow read: if isSignedIn();
        // Friends can add themselves to the guest list
        allow write: if isSignedIn();
      }
    }

    // Shared Statuses (Denormalized fulfillment tracking)
    match /sharedWishlistStatuses/{itemId} {
      // Allow reading fulfillment status if signed in
      allow read: if isSignedIn();
      // Friends can "tick off" items (create/update fulfillment)
      allow create, update: if isSignedIn();
      // Only the owner of the target item can clear/delete the status
      // We check the 'userId' field stored in the document
      allow delete: if isSignedIn() && (
        (resource != null && resource.data.userId == request.auth.uid) ||
        (request.resource != null && request.resource.data.userId == request.auth.uid)
      );
    }

    // Admin Roles (DBAC)
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Managed via console
    }
  }
}