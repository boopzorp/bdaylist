rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * WISHSTREAM SECURITY RULES
     * 
     * Architecture:
     * - /userProfiles/{userId}: Profile info. Owner writes, everyone reads.
     * - /userProfiles/{userId}/wishlistItems/{itemId}: The actual wishlist. Owner writes, everyone reads.
     * - /sharedWishlistStatuses/{itemId}: Fulfillment tracking. Everyone reads/writes (to tick off items).
     * - /userProfiles/{userId}/guests/list: Guestbook. Everyone reads/writes (to join stream).
     */

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Rules ---

    // User Profiles: Everyone can see a profile, only owner can edit.
    match /userProfiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);

      // Wishlist Items: Everyone can see the items (to buy them!), only owner can manage the list.
      match /wishlistItems/{itemId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }

      // Guestbook: Anyone can see the guest list and add themselves to it.
      match /guests/list {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    // Shared Statuses: This is where friends "tick off" items.
    // It's a separate collection to keep the "secret" from the owner (Admin).
    match /sharedWishlistStatuses/{itemId} {
      allow read: if isSignedIn();
      // Friends write to this collection to fulfill items. 
      // Admin also writes here if they manually mark something as purchased.
      allow create, update: if isSignedIn();
      // Only the owner of the target item should be able to clear/delete the status.
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Admin Roles (DBAC)
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Managed via console
    }
  }
}